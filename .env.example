# Required for daily-exporter GitHub push
GITHUB_REPO=https://github.com/<owner>/<repo>.git
GITHUB_USERNAME=<github-username>
GITHUB_TOKEN=<github-personal-access-token>
SOURCE_NAME=Reefz Server

# Frontend historical source (raw github file base to exports directory)
# Example: https://raw.githubusercontent.com/<owner>/<repo>/main/exports
FRONTEND_GITHUB_RAW_BASE_URL=https://raw.githubusercontent.com/<owner>/<repo>/main/exports

# Optional local overrides
# FRONTEND_API_BASE_URL=https://deployment-data-api.reefz.cc
# FRONTEND_API_BASE_URL=http://localhost:13001
# PROMETHEUS_PORT=19090
# ALLOWED_ORIGINS=https://deployment-data-api.reefz.cc,http://localhost:13002
# ALLOWED_ORIGIN_SUFFIXES=.github.io
